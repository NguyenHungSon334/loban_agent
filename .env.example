# Bắt buộc — API key Gemini (bước vision bóc tách kích thước)
LOBAN_GEMINI_API_KEY=

# Tên miền cho HTTPS tự động. Trỏ A record về IP VM trước.
# Bỏ trống -> chạy HTTP cổng 80 (dùng IP tạm).
DOMAIN=

# Tùy chọn — số job nặng chạy song song (khớp RAM VM).
# e2-micro (1GB, free tier) -> 1 · e2-small (2GB) -> 2 · e2-medium (4GB) -> 3-4
LOBAN_WEB_WORKER_CONCURRENCY=1
